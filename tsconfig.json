{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,
    "noImplicitAny": false,

    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,

    "lib": ["ES2022", "DOM"],
    "types": ["node", "jest"],

    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["src/UploadControl.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
  ]
}
